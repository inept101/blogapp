# MongoDB connection string
DB_URL=mongodb+srv://...

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=https://your-app.onrender.com

# Google SSO (optional) — console.cloud.google.com → OAuth 2.0 credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub SSO (optional) — github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Uploadthing image uploads (optional) — uploadthing.com
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# Resend email — resend.com → API Keys
RESEND_API_KEY=
# The from address — must match a verified domain in Resend
EMAIL_FROM=BLOGG <noreply@yourdomain.com>
